{
  "name": "vape-shop-bot",
  "version": "3.0.0",
  "description": "Vape Shop XSS Bot with Docker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "docker:build": "docker build -t vape-shop-bot .",
    "docker:run": "docker run -p 3000:3000 --env-file .env vape-shop-bot"
  },
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "node-telegram-bot-api": "^0.61.0",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1"
  }
}
